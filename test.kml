      <Placemark>
        <name>Cistercian Abbey of Fontenay</name>
        <description><![CDATA[unique_number: 1565<br>id_no: 165<br>rev_bis: Bis<br>short_description_en: <p>This stark Burgundian monastery was founded by St Bernard in 1119. With its church, cloister, refectory, sleeping quarters, bakery and ironworks, it is an excellent illustration of the ideal of self-sufficiency as practised by the earliest communities of Cistercian monks.</p><br>justification_en: <br>date_inscribed: 1981<br>longitude: 4.38911<br>latitude: 47.63944<br>area_hectares: 5.77<br>category: Cultural<br>category_short: C<br>states_name_en: France<br>region_en: Europe and North America<br>iso_code: fr<br>transboundary: 0]]></description>
