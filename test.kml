            <value>1692.0</value>
          </Data>
          <Data name="rev_bis">
            <value/>
          </Data>
          <Data name="short_description_en">
            <value>This serial property is an unusually well-preserved and extensive epigenic gypsum karst terrain. It includes a very high density of caves: over 900 caves in a relatively small area, with over 100 km of caves in total. It is the first and the best studied evaporitic karst in the world, with academic work beginning in the 16th century. It also includes some of the deepest gypsum caves in existence, reaching 265 meters below the surface.</value>
          </Data>
          <Data name="justification_en">
            <value/>
          </Data>
